# LLM API Keys
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key
GEMINI_API_KEY=your-gemini-api-key
OPENROUTER_API_KEY=your-openrouter-api-key
DEEPSEEK_API_KEY=your-deepseek-api-key
LITELLM_API_KEY=your-litellm-api-key
OLLAMA_API_KEY=your-ollama-api-key

# Tool API Keys
TAVILY_API_KEY=your-tavily-api-key

# Default user for CLI (used when --user is not specified)
CHAT_AGENT_USER=your-username

# Gmail Adapter (OAuth2 - optional, see docs/dev/gmail-oauth-setup.md)
GMAIL_CLIENT_ID=your-gmail-client-id
GMAIL_CLIENT_SECRET=your-gmail-client-secret
GMAIL_REFRESH_TOKEN=your-gmail-refresh-token

# Discord Adapter (self-bot, optional)
DISCORD_TOKEN=your-discord-token

# Claude Code proxy - LAN/remote access (optional; leave commented for localhost-only)
# The supervisor injects this file into every managed process, so setting these
# here is enough -- no shell exports needed.
# Localhost requests never need a key. Non-localhost requests must send the key
# via `x-api-key` or `Authorization: Bearer`, and are rejected with 401 when no
# key is configured (fail closed).
#
# 1. Generate a strong key (do NOT ship a guessable placeholder):
#      openssl rand -hex 32
# 2. Uncomment both lines and paste the generated key:
# CLAUDE_CODE_PROXY_HOST=0.0.0.0
# CLAUDE_CODE_PROXY_API_KEY=paste-output-of-openssl-rand-hex-32
